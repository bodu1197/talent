# Supabase 설정
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PortOne 설정
# 테스트: store-test-xxxxx
# 프로덕션: store-xxxxx
NEXT_PUBLIC_PORTONE_STORE_ID=your-store-id
PORTONE_API_SECRET=your-api-secret
NEXT_PUBLIC_PORTONE_CHANNEL_KEY=your-channel-key

# Sentry 에러 모니터링 (선택사항)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=your-auth-token

# 플랫폼 무통장 입금 계좌 정보
NEXT_PUBLIC_BANK_NAME=은행명
NEXT_PUBLIC_BANK_ACCOUNT=계좌번호
NEXT_PUBLIC_BANK_HOLDER=예금주명
